   "source": [
    "# NB7 \u2014 MES Top-N Gene Cutoff Sensitivity\n\nRe-scores all eight MES modules using the top-25, top-50, and top-100 NMF-weight-ranked\ngenes and recomputes MES-tolerance-positioning Spearman correlations across all four\nmicroglia cohorts. This confirms that the fixed top-50 cutoff used in the main analysis\nis not a critical parameter.\n\n**Paper:** Zafar SA, Qin W, Liu C, Khan AA, Faisal MS.\n*Thymus-derived myeloid programs track microglial tolerance states across human cohorts.* (2026).\n\n**Outputs:**\n- `Supplementary Table S7` \u2014 long-form correlations and pivot table\n- `Supplementary Fig S7` \u2014 heatmap per cohort\n\n> Set `MES_BASE_DIR` to your project root before running."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code",
   "metadata": {},
   "outputs": [],
   "source": [
    "from __future__ import annotations\n",
    "\n",
    "import os, time, gc, warnings, traceback\n",
    "from pathlib import Path\n",
    "from typing import Dict, List, Optional\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import scipy.stats as scipy_stats\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import matplotlib\n",
    "matplotlib.rcParams.update({\n",
    "    \"font.family\":        \"Arial\",\n",
    "    \"font.size\":          8,\n",
    "    \"axes.titlesize\":     9,\n",
    "    \"axes.labelsize\":     8,\n",
    "    \"xtick.labelsize\":    7,\n",
    "    \"ytick.labelsize\":    7,\n",
    "    \"legend.fontsize\":    7,\n",
    "    \"figure.dpi\":         150,\n",
    "    \"savefig.dpi\":        1200,\n",
    "    \"savefig.bbox\":       \"tight\",\n",
    "    \"savefig.pad_inches\": 0.05,\n",
    "    \"axes.linewidth\":     0.8,\n",
    "    \"xtick.major.width\":  0.6,\n",
    "    \"ytick.major.width\":  0.6,\n",
    "    \"xtick.major.size\":   3,\n",
    "    \"ytick.major.size\":   3,\n",
    "    \"pdf.fonttype\":       42,\n",
    "    \"ps.fonttype\":        42,\n",
    "})\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "try:\n",
    "    import seaborn as sns\n",
    "    sns.set_style('ticks')\n",
    "    HAS_SNS = True\n",
    "except ImportError:\n",
    "    HAS_SNS = False\n",
    "\n",
    "import anndata as ad\n",
    "import scanpy as sc\n",
    "\n",
    "try:\n",
    "    from statsmodels.stats.multitest import multipletests\n",
    "    HAS_SM = True\n",
    "except ImportError:\n",
    "    HAS_SM = False\n",
    "\n",
    "\n",
    "# 0) Paths\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "BASE_DIR  = Path(os.environ.get(\"MES_BASE_DIR\", \".\"))  # <-- SET PATH\n",
    "PROC_DIR  = BASE_DIR / \"Process Data\",
    "MANUS_DIR_CANDIDATES = [BASE_DIR / \"Manuscript data\", BASE_DIR / \"Manuscript Data\"]\n",
    "MANUS_DIR = next((p for p in MANUS_DIR_CANDIDATES if p.exists()), MANUS_DIR_CANDIDATES[0])\n",
    "TAB_DIR   = MANUS_DIR / \"Tables\"\n",
    "FIG_DIR   = MANUS_DIR / \"Figures\"\n",
    "TAB_DIR.mkdir(parents=True, exist_ok=True)\n",
    "FIG_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# NMF weights table from NB3\n",
    "WEIGHTS_PATH_CANDIDATES = [\n",
    "    MANUS_DIR / \"Tables\" / \"Main_Table1.xlsx\",\n",
    "    BASE_DIR / \"Manuscript Data\" / \"Tables\" / \"Main_Table1.xlsx\",\n",
    "]\n",
    "WEIGHTS_PATH = next((p for p in WEIGHTS_PATH_CANDIDATES if p.exists()), None)\n",
    "assert WEIGHTS_PATH is not None, (\n",
    "    \"Main_Table1.xlsx not found. Re-run NB3 first.\"\n",
    ")\n",
    "\n",
    "SCORED_GLOB = str(PROC_DIR / \"*__microglia_scored.h5ad\")\n",
    "\n",
    "DPI            = 1200\n",
    "N_BOOT         = 500\n",
    "TOP_N_VARIANTS = [25, 50, 100]\n",
    "MES_COLS       = [f\"MES0{i}\" for i in range(1, 9)]\n",
    "\n",
    "\n",
    "# 1) Utilities\n",
    "\n",
    "def _now() -> str:\n",
    "    return time.strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "\n",
    "def log(msg: str) -> None:\n",
    "    print(f\"[{_now()}] {msg}\", flush=True)\n",
    "\n",
    "def save_fig(path: Path, fig=None) -> None:\n",
    "    path.parent.mkdir(parents=True, exist_ok=True)\n",
    "    (fig or plt).savefig(path, dpi=DPI, bbox_inches=\"tight\")\n",
    "    plt.close(fig) if fig is not None else plt.close()\n",
    "    log(f\"[SAVED FIG] {path}\")\n",
    "\n",
    "def save_xlsx(dfs: Dict[str, pd.DataFrame], path: Path) -> None:\n",
    "    path.parent.mkdir(parents=True, exist_ok=True)\n",
    "    with pd.ExcelWriter(path, engine=\"openpyxl\") as w:\n",
    "        for name, df in dfs.items():\n",
    "            if df is not None and not df.empty:\n",
    "                df.to_excel(w, index=False, sheet_name=name[:31])\n",
    "    log(f\"[SAVED TABLE] {path}\")\n",
    "\n",
    "def bh_fdr(pvals: np.ndarray) -> np.ndarray:\n",
    "    pvals = np.asarray(pvals, dtype=float)\n",
    "    if HAS_SM:\n",
    "        _, q, _, _ = multipletests(pvals, method=\"fdr_bh\")\n",
    "        return q\n",
    "    n = len(pvals)\n",
    "    order = np.argsort(pvals)\n",
    "    q = np.empty(n)\n",
    "    q[order] = pvals[order] * n / (np.arange(n) + 1)\n",
    "    q = np.minimum.accumulate(q[::-1])[::-1]\n",
    "    return np.minimum(q, 1.0)\n",
    "\n",
    "def spearman_ci(x, y, n_boot=N_BOOT, seed=42) -> Dict:\n",
    "    x = pd.to_numeric(x, errors=\"coerce\").to_numpy()\n",
    "    y = pd.to_numeric(y, errors=\"coerce\").to_numpy()\n",
    "    m = np.isfinite(x) & np.isfinite(y)\n",
    "    x, y = x[m], y[m]\n",
    "    n = len(x)\n",
    "    if n < 5:\n",
    "        return {\"r\": np.nan, \"ci_lo\": np.nan, \"ci_hi\": np.nan, \"p\": np.nan, \"n\": n}\n",
    "    r_obs, p_obs = scipy_stats.spearmanr(x, y)\n",
    "    rng = np.random.default_rng(seed)\n",
    "    boots = np.array([\n",
    "        scipy_stats.spearmanr(x[idx := rng.integers(0, n, n)], y[idx])[0]\n",
    "        for _ in range(n_boot)\n",
    "    ])\n",
    "    boots = boots[np.isfinite(boots)]\n",
    "    ci_lo = float(np.percentile(boots, 2.5))  if len(boots) else np.nan\n",
    "    ci_hi = float(np.percentile(boots, 97.5)) if len(boots) else np.nan\n",
    "    return {\"r\": float(r_obs), \"ci_lo\": ci_lo, \"ci_hi\": ci_hi, \"p\": float(p_obs), \"n\": n}\n",
    "\n",
    "def detect_donor_col(obs: pd.DataFrame) -> Optional[str]:\n",
    "    for c in ['donor_id','donor','subject','SubjectID','subject_id',\n",
    "              'individualID','individual_id','case_id','participant_id']:\n",
    "        if c in obs.columns and 2 <= obs[c].nunique() <= 500:\n",
    "            return c\n",
    "    return None\n",
    "\n",
    "def donor_mean(obs: pd.DataFrame, donor_col: str, cols: List[str]) -> pd.DataFrame:\n",
    "    cols = [c for c in cols if c in obs.columns]\n",
    "    return obs.groupby(donor_col)[cols].mean().reset_index()\n",
    "\n",
    "def score_genes(adata: ad.AnnData, genes: List[str], key: str, min_present: int = 3) -> int:\n",
    "    vu = adata.var_names.astype(str).str.upper()\n",
    "    u2o = dict(zip(vu, adata.var_names))\n",
    "    present = [u2o[g.upper()] for g in genes if g.upper() in u2o]\n",
    "    if len(present) < min_present:\n",
    "        return 0\n",
    "    try:\n",
    "        sc.tl.score_genes(adata, present, score_name=key, use_raw=False)\n",
    "    except Exception:\n",
    "        return 0\n",
    "    return len(present)\n",
    "\n",
    "TOL_H = [\"P2RY12\",\"CX3CR1\",\"TMEM119\",\"GPR34\",\"SALL1\",\"CSF1R\",\"OLFML3\"]\n",
    "TOL_A = [\"APOE\",\"SPP1\",\"LPL\",\"TREM2\",\"CST7\",\"CTSD\",\"TYROBP\",\"FCER1G\",\"LGALS3\",\"CD68\"]\n",
    "\n",
    "def ensure_tolerance(adata: ad.AnnData) -> None:\n",
    "    if \"tolerance_positioning\" not in adata.obs.columns:\n",
    "        score_genes(adata, TOL_H, '_th7')\n",
    "        score_genes(adata, TOL_A, '_ta7')\n",
    "        if '_th7' in adata.obs and '_ta7' in adata.obs:\n",
    "            adata.obs['tolerance_positioning'] = adata.obs['_th7'] - adata.obs['_ta7']\n",
    "\n",
    "\n",
    "# 2) Load NMF weights\n",
    "\n",
    "log(\"NB7: MES top-N gene cutoff sensitivity\")\n",
    "log(f\"Loading NMF weights from {WEIGHTS_PATH}\")\n",
    "\n",
    "df_w = pd.read_excel(WEIGHTS_PATH, sheet_name=0)\n",
    "gene_col = df_w.columns[0]\n",
    "df_w = df_w.rename(columns={gene_col: \"gene\"})\n",
    "df_w[\"gene\"] = df_w[\"gene\"].astype(str).str.upper().str.strip()\n",
    "wt_cols = [c for c in df_w.columns if str(c).startswith('MES')]\n",
    "assert len(wt_cols) == 8, f'Expected 8 MES columns, got {wt_cols}'\n",
    "log(f\"  {len(df_w)} genes, modules: {wt_cols}\")\n",
    "\n",
    "\n",
    "# 3) Load scored microglia cohorts\n",
    "\n",
    "import glob as _glob\n",
    "log(\"Loading scored microglia cohorts ...\")\n",
    "h5ads = sorted(_glob.glob(SCORED_GLOB))\n",
    "assert len(h5ads) >= 4, f'Expected >=4 scored .h5ad files, found {len(h5ads)}. Re-run NB4/NB5 first.'\n",
    "\n",
    "cohorts: Dict[str, ad.AnnData] = {}\n",
    "for fp in h5ads:\n",
    "    name = Path(fp).stem.replace('__microglia_scored', '')\n",
    "    log(f\"  {name}\")\n",
    "    cohorts[name] = sc.read_h5ad(fp)\n",
    "    gc.collect()\n",
    "log(f\"Loaded {len(cohorts)} cohorts\")\n",
    "\n",
    "\n",
    "# 4) Score each cohort at top-25, top-50, top-100 and correlate with tolerance\n",
    "\n",
    "log(\"Scoring top-N cutoff variants ...\")\n",
    "rows = []\n",
    "\n",
    "for ds, adata in cohorts.items():\n",
    "    log(f\"  {ds}\")\n",
    "    ensure_tolerance(adata)\n",
    "    if 'tolerance_positioning' not in adata.obs.columns:\n",
    "        continue\n",
    "\n",
    "    donor_col = detect_donor_col(adata.obs)\n",
    "    score_cols = ['tolerance_positioning']\n",
    "\n",
    "    for topN in TOP_N_VARIANTS:\n",
    "        for mes in wt_cols:\n",
    "            genes = (\n",
    "                df_w[['gene', mes]].dropna()\n",
    "                .sort_values(mes, ascending=False)\n",
    "                .head(topN)['gene']\n",
    "                .tolist()\n",
    "            )\n",
    "            col = f'{mes}_top{topN}'\n",
    "            if score_genes(adata, genes, col) > 0:\n",
    "                score_cols.append(col)\n",
    "\n",
    "    avail = [c for c in score_cols if c in adata.obs.columns]\n",
    "    if donor_col:\n",
    "        ddf   = donor_mean(adata.obs, donor_col, avail)\n",
    "        level = 'donor'\n",
    "    else:\n",
    "        ddf   = adata.obs[avail].copy()\n",
    "        level = 'cell'\n",
    "\n",
    "    for topN in TOP_N_VARIANTS:\n",
    "        for mes in wt_cols:\n",
    "            col = f'{mes}_top{topN}'\n",
    "            if col not in ddf.columns:\n",
    "                continue\n",
    "            r = spearman_ci(ddf['tolerance_positioning'], ddf[col])\n",
    "            rows.append({'dataset': ds, 'level': level, 'MES': mes,\n",
    "                         'top_N': topN, 'N': r['n'], 'r': r['r'],\n",
    "                         'ci_lo': r['ci_lo'], 'ci_hi': r['ci_hi'], 'p': r['p']})\n",
    "    gc.collect()\n",
    "\n",
    "df = pd.DataFrame(rows)\n",
    "df['q_BH'] = bh_fdr(df['p'].fillna(1).values)\n",
    "\n",
    "\n",
    "# 5) Build pivot and summary\n",
    "\n",
    "pivot = df.pivot_table(index=['dataset','MES'], columns='top_N', values='r', aggfunc='mean')\n",
    "pivot.columns = [f'rho_top{c}' for c in pivot.columns]\n",
    "pivot = pivot.reset_index()\n",
    "\n",
    "if 'rho_top25' in pivot.columns and 'rho_top50' in pivot.columns:\n",
    "    pivot['delta_25_vs_50']  = pivot['rho_top25']  - pivot['rho_top50']\n",
    "if 'rho_top100' in pivot.columns and 'rho_top50' in pivot.columns:\n",
    "    pivot['delta_100_vs_50'] = pivot['rho_top100'] - pivot['rho_top50']\n",
    "\n",
    "if 'delta_25_vs_50' in pivot.columns:\n",
    "    med = pivot['delta_25_vs_50'].abs().median()\n",
    "    log(f\"  Median |Delta_rho| top-25 vs top-50: {med:.4f} (manuscript value: 0.063)\")\n",
    "if 'delta_100_vs_50' in pivot.columns:\n",
    "    med2 = pivot['delta_100_vs_50'].abs().median()\n",
    "    log(f\"  Median |Delta_rho| top-100 vs top-50: {med2:.4f} (manuscript value: 0.041)\")\n",
    "\n",
    "save_xlsx({\"long_form\": df, \"pivot_r_by_topN\": pivot},\n",
    "          TAB_DIR / \"Supplementary_TableS7_TopN_Cutoff_Sensitivity.xlsx\")\n",
    "\n",
    "\n",
    "# 6) Figure\n",
    "\n",
    "datasets = df['dataset'].unique().tolist()\n",
    "n_ds  = len(datasets)\n",
    "n_col = min(n_ds, 4)\n",
    "n_row = int(np.ceil(n_ds / n_col))\n",
    "\n",
    "fig, axes = plt.subplots(n_row, n_col, figsize=(n_col * 3.5, n_row * 3.2), squeeze=False)\n",
    "\n",
    "for idx, ds in enumerate(datasets):\n",
    "    ax  = axes[idx // n_col][idx % n_col]\n",
    "    sub = df[df['dataset'] == ds]\n",
    "    mat = sub.pivot(index='MES', columns='top_N', values='r').reindex(index=wt_cols)\n",
    "    mat.columns = [f'Top-{c}' for c in mat.columns]\n",
    "    im = ax.imshow(mat.values.astype(float), cmap=\"RdBu_r\", vmin=-0.8, vmax=0.8, aspect=\"auto\")\n",
    "    ax.set_xticks(range(len(mat.columns)))\n",
    "    ax.set_xticklabels(mat.columns, fontsize=7)\n",
    "    ax.set_yticks(range(len(mat.index)))\n",
    "    ax.set_yticklabels(mat.index, fontsize=7)\n",
    "    ax.set_title(ds.replace('_',' '), fontsize=8, pad=4)\n",
    "    for ri in range(mat.shape[0]):\n",
    "        for ci in range(mat.shape[1]):\n",
    "            v = mat.values[ri, ci]\n",
    "            if np.isfinite(v):\n",
    "                ax.text(ci, ri, f'{v:.2f}', ha='center', va='center', fontsize=6,\n",
    "                        color='white' if abs(v) > 0.4 else 'black')\n",
    "    plt.colorbar(im, ax=ax, shrink=0.7, label=\"Spearman rho\", pad=0.02)\n",
    "\n",
    "for idx in range(n_ds, n_row * n_col):\n",
    "    axes[idx // n_col][idx % n_col].set_visible(False)\n",
    "\n",
    "fig.suptitle('MES-Tolerance Correlation: Top-N Gene Cutoff Sensitivity', fontsize=9, y=1.01)\n",
    "plt.tight_layout()\n",
    "save_fig(FIG_DIR / \"Supplementary_FigS7_TopN_Cutoff_Sensitivity.png\", fig)\n",
    "\n",
    "\n",
    "# Done\n",
    "\n",
    "log(\"NB7 COMPLETED\")\n",
    "log(f\"  Tables:  {TAB_DIR}\")\n",
    "log(f\"  Figures: {FIG_DIR}\")\n",
    "log(\"  Supplementary_TableS7_TopN_Cutoff_Sensitivity.xlsx\")\n",
    "log(\"    long_form    \u2014 rho, CI, p, q_BH per (dataset, MES, top_N)\")\n",
    "log(\"    pivot_r_by_topN \u2014 rho at top-25/50/100 with delta columns\")\n",
    "log(\"  Supplementary_FigS7_TopN_Cutoff_Sensitivity.png\")\n"
   ]
  }
 ]
}
